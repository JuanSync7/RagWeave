FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app

WORKDIR /app

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install all project dependencies from pyproject.toml.
COPY pyproject.toml /app/pyproject.toml
RUN pip install --upgrade pip && pip install .

RUN groupadd --system app && useradd --system --gid app --create-home app \
    && mkdir -p /home/app/.litellm /app/logs \
    && chown -R app:app /home/app /app/logs

COPY --chown=app:app config /app/config
COPY --chown=app:app src /app/src
COPY --chown=app:app server /app/server
COPY --chown=app:app prompts /app/prompts

USER app

ARG RAG_API_PORT=8000
ENV RAG_API_PORT=${RAG_API_PORT}

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -fsS http://127.0.0.1:${RAG_API_PORT}/health >/dev/null || exit 1

CMD uvicorn server.api:app --host 0.0.0.0 --port ${RAG_API_PORT}

# syntax=docker/dockerfile:1
# --- Builder stage: installs deps with gcc available ---
FROM python:3.11-slim-bookworm AS builder

# PIP_NO_CACHE_DIR intentionally omitted — the BuildKit cache mount below
# persists pip's wheel cache across rebuilds (speeds up dep-change rebuilds)
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY containers/requirements-api.txt /app/requirements-api.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip && pip install --prefix=/install -r /app/requirements-api.txt \
    && find /install -type d -name __pycache__ -prune -exec rm -rf {} + \
    && find /install -type d -name tests -prune -exec rm -rf {} + \
    && find /install -type d -name test -prune -exec rm -rf {} + \
    && find /install -name "*.pyc" -delete \
    && find /install -name "*.pyo" -delete

# --- Runtime stage: no build tools, no gcc ---
FROM python:3.11-slim-bookworm AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app \
    PYTHONUSERBASE=/install

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder (no build tools come along)
COPY --from=builder /install /usr/local

RUN groupadd --system app && useradd --system --gid app --create-home app \
    && mkdir -p /home/app/.litellm /app/logs \
    && chown -R app:app /home/app /app/logs

COPY --chown=app:app config /app/config
COPY --chown=app:app src /app/src
COPY --chown=app:app server /app/server
COPY --chown=app:app prompts /app/prompts

USER app

ARG RAG_API_PORT=8000
ENV RAG_API_PORT=${RAG_API_PORT}

# Health check uses Python stdlib — no curl dependency needed
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD python -c "import os,urllib.request; urllib.request.urlopen('http://127.0.0.1:' + os.environ.get('RAG_API_PORT','8000') + '/health')" || exit 1

CMD ["uvicorn", "server.api:app", "--host", "0.0.0.0", "--port", "${RAG_API_PORT}"]

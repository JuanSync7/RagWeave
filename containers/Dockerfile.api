# syntax=docker/dockerfile:1
# --- Builder stage: installs deps with gcc available ---
FROM python:3.11-slim-bookworm AS builder

# uv cache lives at /root/.cache/uv; the BuildKit mount below persists it.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# uv: 10–100× faster than pip, honors pyproject.toml [tool.uv.sources] pins,
# matches the project-wide tooling (see memory: prefer uv over pip).
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml /app/pyproject.toml
COPY containers/requirements-api.txt /app/requirements-api.txt
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system --prefix=/install -r /app/requirements-api.txt \
    && find /install -type d -name __pycache__ -prune -exec rm -rf {} + \
    && find /install -type d -name tests -prune -exec rm -rf {} + \
    && find /install -type d -name test -prune -exec rm -rf {} + \
    && find /install -name "*.pyc" -delete \
    && find /install -name "*.pyo" -delete

# --- Runtime stage: no build tools, no gcc ---
FROM python:3.11-slim-bookworm AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app \
    PYTHONUSERBASE=/install

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder (no build tools come along)
COPY --from=builder /install /usr/local

RUN groupadd --system app && useradd --system --gid app --create-home app \
    && mkdir -p /home/app/.litellm /app/logs \
    && chown -R app:app /home/app /app/logs

COPY --chown=app:app config /app/config
COPY --chown=app:app src /app/src
COPY --chown=app:app server /app/server
COPY --chown=app:app prompts /app/prompts

USER app

ARG RAG_API_PORT=8000
ENV RAG_API_PORT=${RAG_API_PORT}

# Health check is defined in docker-compose.yml so it works with both
# docker and podman (podman drops HEALTHCHECK directives when building in
# the default OCI image format — compose-level healthcheck is respected by
# both docker-compose and podman-compose regardless of image format).

CMD ["uvicorn", "server.api:app", "--host", "0.0.0.0", "--port", "${RAG_API_PORT}"]

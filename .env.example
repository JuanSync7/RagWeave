# ============================================================
# Service Ports — single source of truth for all port numbers.
# Change a port here and every reference picks it up.
# ============================================================
RAG_API_PORT=8000
RAG_API_HOST_PORT=8000
RAG_OLLAMA_PORT=11434
RAG_OLLAMA_PROXY_PORT=11435
RAG_REDIS_PORT=6379
RAG_TEMPORAL_PORT=7233
RAG_TEMPORAL_UI_PORT=8080
LANGFUSE_PORT=3000
GRAFANA_HOST_PORT=3001
PROMETHEUS_HOST_PORT=9091
ALERTMANAGER_HOST_PORT=9093
DOZZLE_HOST_PORT=9999
MINIO_HOST_PORT=9090

# --- Derived URLs (built from ports above) ---
RAG_API_URL=http://localhost:${RAG_API_PORT}
RAG_OLLAMA_URL=http://localhost:${RAG_OLLAMA_PORT}
RAG_LLM_API_BASE=http://localhost:${RAG_OLLAMA_PORT}
RAG_CACHE_REDIS_URL=redis://localhost:${RAG_REDIS_PORT}/0
RAG_MEMORY_REDIS_URL=redis://localhost:${RAG_REDIS_PORT}/0

# --- Server ---
RAG_API_MAX_INFLIGHT_REQUESTS=64
RAG_API_OVERLOAD_QUEUE_TIMEOUT_MS=250

# --- Observability ---
RAG_OBSERVABILITY_PROVIDER=langfuse
LANGFUSE_HOST=http://localhost:${LANGFUSE_PORT}
LANGFUSE_PUBLIC_KEY=pk_replace_me
LANGFUSE_SECRET_KEY=sk_replace_me
LANGFUSE_NEXTAUTH_URL=http://localhost:${LANGFUSE_PORT}
LANGFUSE_NEXTAUTH_SECRET=replace_me
LANGFUSE_SALT=replace_me
LANGFUSE_ENCRYPTION_KEY=replace_me

# --- Auth ---
RAG_AUTH_API_KEYS_REQUIRED=false
RAG_AUTH_API_KEYS_JSON={}
RAG_AUTH_JWT_ENABLED=false
RAG_AUTH_JWT_HS256_SECRET=replace_me
RAG_AUTH_OIDC_ENABLED=false
RAG_AUTH_OIDC_ISSUER=https://issuer.example.com/
RAG_AUTH_OIDC_AUDIENCE=rag-api
RAG_AUTH_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
RAG_AUTH_OIDC_ROLES_CLAIM=roles
RAG_AUTH_OIDC_TENANT_CLAIM=tenant_id
RAG_AUTH_OIDC_SUBJECT_CLAIM=sub
RAG_DEFAULT_TENANT_ID=default
RAG_AUTH_API_KEYS_STORE_PATH=.runtime/security/api_keys.json
RAG_AUTH_QUOTAS_STORE_PATH=.runtime/security/quotas.json

# --- Rate limiting ---
RAG_RATE_LIMIT_ENABLED=true
RAG_RATE_LIMIT_REQUESTS_PER_MINUTE=60
RAG_RATE_LIMIT_WINDOW_SECONDS=60

# --- Cache ---
RAG_CACHE_ENABLED=true
RAG_CACHE_PROVIDER=redis
RAG_CACHE_TTL_SECONDS=120

# --- Conversation memory ---
RAG_MEMORY_ENABLED=true
RAG_MEMORY_PROVIDER=redis
RAG_MEMORY_REDIS_PREFIX=rag:memory
RAG_MEMORY_MAX_RECENT_TURNS=8
RAG_MEMORY_MAX_CONTEXT_TOKENS_ESTIMATE=1400
RAG_MEMORY_SUMMARY_TRIGGER_TURNS=12
RAG_MEMORY_SUMMARY_MAX_SOURCE_TURNS=40

# --- Retrieval ---
RAG_DEFAULT_FAST_PATH=false
RAG_RETRIEVAL_TIMEOUT_MS=30000
RAG_STAGE_BUDGET_QUERY_PROCESSING_MS=12000
RAG_STAGE_BUDGET_KG_EXPANSION_MS=1000
RAG_STAGE_BUDGET_EMBEDDING_MS=1500
RAG_STAGE_BUDGET_HYBRID_SEARCH_MS=5000
RAG_STAGE_BUDGET_RERANKING_MS=5000
RAG_STAGE_BUDGET_GENERATION_MS=60000

# --- LLM ---
RAG_LLM_MODEL=ollama/qwen2.5:3b
RAG_LLM_API_KEY=
RAG_LLM_FALLBACK_MODELS=
RAG_LLM_VISION_MODEL=ollama/qwen2.5vl:3b
RAG_LLM_QUERY_MODEL=
RAG_LLM_MAX_TOKENS=1024
RAG_LLM_TEMPERATURE=0.3
RAG_LLM_NUM_RETRIES=3
RAG_LLM_ROUTER_CONFIG=

# --- Ingestion ---
RAG_INGESTION_LLM_ENABLED=true
RAG_INGESTION_LLM_MODEL=qwen2.5:3b
RAG_INGESTION_LLM_TEMPERATURE=0.1
RAG_INGESTION_LLM_TIMEOUT_SECONDS=45
RAG_INGESTION_LLM_MAX_KEYWORDS=12
RAG_INGESTION_DOCLING_ENABLED=true
RAG_INGESTION_DOCLING_MODEL=docling-parse-v2
RAG_INGESTION_DOCLING_ARTIFACTS_PATH=
RAG_INGESTION_DOCLING_STRICT=true
RAG_INGESTION_DOCLING_AUTO_DOWNLOAD=true
RAG_INGESTION_EXPORT_EXTENSIONS=.txt,.md,.markdown,.rst,.html,.htm,.pdf,.docx,.pptx
RAG_INGESTION_ENABLE_MULTIMODAL_PROCESSING=false
RAG_INGESTION_VISION_ENABLED=false
RAG_INGESTION_VISION_PROVIDER=ollama
RAG_INGESTION_VISION_MODEL=qwen2.5vl:3b
RAG_INGESTION_VISION_TIMEOUT_SECONDS=60
RAG_INGESTION_VISION_MAX_FIGURES=4
RAG_INGESTION_VISION_MAX_IMAGE_BYTES=3145728
RAG_INGESTION_VISION_TEMPERATURE=0.1
RAG_INGESTION_VISION_MAX_TOKENS=220
RAG_INGESTION_VISION_AUTO_PULL=true
RAG_INGESTION_VISION_STRICT=false
RAG_INGESTION_VISION_API_BASE_URL=
RAG_INGESTION_VISION_API_KEY=
RAG_INGESTION_VISION_API_PATH=/v1/chat/completions

# ============================================================
# Container Runtime (Podman)
# Uncomment the line below if using Podman instead of Docker.
# This tells Dozzle (container log viewer) where to find the
# container socket. Docker users can ignore this.
# ============================================================
# CONTAINER_SOCK=$XDG_RUNTIME_DIR/podman/podman.sock

RAG_INGESTION_ENABLE_DOCUMENT_REFACTORING=false
RAG_INGESTION_ENABLE_CROSS_REFERENCE_EXTRACTION=true
RAG_INGESTION_ENABLE_KNOWLEDGE_GRAPH_EXTRACTION=true
RAG_INGESTION_ENABLE_QUALITY_VALIDATION=true
RAG_INGESTION_ENABLE_KNOWLEDGE_GRAPH_STORAGE=true
RAG_INGESTION_VERBOSE_STAGE_LOGS=false
RAG_INGESTION_PERSIST_REFACTOR_MIRROR=true

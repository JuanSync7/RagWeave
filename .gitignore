# Weaviate data
.weaviate_data/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# Node
node_modules/

# Processed data (regenerable)
processed/*.json
processed/*.md
!processed/README.md

# Knowledge graph (regenerable)
.knowledge_graph.json

# Logs
logs/*.log
!logs/README.md

# Context cache
.context/

# Runtime state (certs, API keys, quotas)
.runtime/

# Environment
.env

# UV tools cache
.uv-tools/

# User documents (keep sample docs, ignore user-added files)
# documents/

# Model cache
models/

# TLS certs (generated locally via mkcert)
certs/*
!certs/.gitkeep
!certs/README.md

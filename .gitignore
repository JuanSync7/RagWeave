.coverage
.coverage.*
htmlcov/

# Local container data dirs (regenerated on stack up)
.ollama_data/
.tei_cache/

# Ad-hoc ingest corpora (cloned beside the repo, not source)
opentitan_data/

# Per-iteration bench result JSONs — ignore everything new; the tracked
# baselines (cpu-1777015485.json, gpu-1777015578.json, baseline_report.md)
# remain tracked because git ignores only affect untracked files.
scripts/.bench_results/*.json
!scripts/.bench_results/cpu-1777015485.json
!scripts/.bench_results/gpu-1777015578.json

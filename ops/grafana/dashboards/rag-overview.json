{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_api_requests_total[5m])) by (endpoint)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_api_request_latency_ms_bucket[5m])) by (le, endpoint, method))"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Stage Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_pipeline_stage_ms_sum[5m])) by (stage)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_rate_limit_rejections_total[5m])) by (endpoint)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "refresh": "10s",
